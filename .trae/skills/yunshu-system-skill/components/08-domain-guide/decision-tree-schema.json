{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://yunshu.system/schemas/decision-tree.schema.json",
  "title": "Yunshu Domain Decision Tree",
  "description": "领域细分引导决策树 Schema。定义层级结构、选项、约束和上下文注入规则。",
  "type": "object",
  "required": ["domain_id", "version", "levels"],
  "properties": {
    "domain_id": {
      "type": "string",
      "description": "领域唯一标识，使用 kebab-case",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "examples": ["road-design", "building-structural", "bridge-design"]
    },
    "version": {
      "type": "string",
      "description": "决策树版本，遵循语义化版本",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "description": "领域显示名称"
    },
    "description": {
      "type": "string",
      "description": "领域描述"
    },
    "keywords": {
      "type": "array",
      "description": "触发领域识别的关键词列表",
      "items": { "type": "string" },
      "minItems": 1
    },
    "levels": {
      "type": "array",
      "description": "决策树层级定义，按顺序执行",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["level", "name", "choices"],
        "properties": {
          "level": {
            "type": "integer",
            "description": "层级编号，从1开始",
            "minimum": 1,
            "maximum": 5
          },
          "name": {
            "type": "string",
            "description": "层级名称（显示给用户）"
          },
          "description": {
            "type": "string",
            "description": "层级说明"
          },
          "selection_mode": {
            "type": "string",
            "description": "选择模式",
            "enum": ["single", "multiple"],
            "default": "single"
          },
          "parent_level": {
            "type": "integer",
            "description": "父层级编号（用于级联过滤）",
            "minimum": 1
          },
          "choices": {
            "type": "array",
            "description": "该层级的选项列表",
            "minItems": 2,
            "maxItems": 10,
            "items": {
              "type": "object",
              "required": ["id", "name"],
              "properties": {
                "id": {
                  "type": "string",
                  "description": "选项唯一标识",
                  "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
                },
                "name": {
                  "type": "string",
                  "description": "选项显示名称"
                },
                "description": {
                  "type": "string",
                  "description": "选项说明"
                },
                "parent_filter": {
                  "type": "array",
                  "description": "父层级选项ID过滤条件（仅当parent_level存在时有效）",
                  "items": { "type": "string" }
                },
                "next_level": {
                  "type": "integer",
                  "description": "下一层级编号（null表示终止）",
                  "minimum": 1,
                  "maximum": 5
                },
                "constraints": {
                  "type": "array",
                  "description": "选择该选项后的约束条件",
                  "items": { "type": "string" }
                },
                "context_inject": {
                  "type": "object",
                  "description": "选择该选项后注入到上下文包的键值对",
                  "additionalProperties": true
                },
                "software_skills": {
                  "type": "array",
                  "description": "该选项关联的软件技能ID列表",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "context_package_template": {
      "type": "object",
      "description": "上下文包模板定义",
      "required": ["required_fields"],
      "properties": {
        "required_fields": {
          "type": "array",
          "description": "上下文包必需字段",
          "items": { "type": "string" }
        },
        "optional_fields": {
          "type": "array",
          "description": "上下文包可选字段",
          "items": { "type": "string" }
        }
      }
    },
    "decomposition_config": {
      "type": "object",
      "description": "动态分解配置，支持无限细分",
      "required": ["enable_dynamic_decomposition"],
      "properties": {
        "enable_dynamic_decomposition": {
          "type": "boolean",
          "description": "是否启用动态分解模式",
          "default": true
        },
        "max_predefined_levels": {
          "type": "integer",
          "description": "预定义决策树的最大层级数，必须 ≤ levels 数组的 maxItems",
          "minimum": 1,
          "maximum": 10,
          "default": 5
        },
        "max_decomposition_depth": {
          "type": "integer",
          "description": "动态分解的最大深度（不含预定义层级），防止无限循环",
          "minimum": 1,
          "maximum": 20,
          "default": 10
        },
        "atomic_task_criteria": {
          "type": "array",
          "description": "原子任务判定标准列表",
          "items": { "type": "string" },
          "default": [
            "任务可在单步内完成，不需要进一步分解",
            "任务有明确的输入和输出",
            "任务的验收标准可自动验证",
            "任务不涉及多个领域的知识",
            "任务描述清晰，不会产生多种理解"
          ]
        },
        "decomposition_trigger": {
          "type": "string",
          "description": "触发动态分解的条件描述"
        },
        "decomposition_prompt_template": {
          "type": "string",
          "description": "动态分解时使用的提示词模板"
        }
      }
    }
  }
}
