# 合规审查项目配置

# 项目根目录绝对路径（必填）
PROJECT_ROOT=E:\traework\000 做网站赚钱\my-project

# 隐私政策文件路径（可选，自动探测）
# PRIVACY_POLICY_PATH=E:\traework\000 做网站赚钱\my-project\privacy.html

# 用户协议文件路径（可选，自动探测）
# TERMS_OF_SERVICE_PATH=E:\traework\000 做网站赚钱\my-project\terms.html

# 部署后的目标URL（可选，用于SSL/安全检测）
# TARGET_URL=https://my-project.example.com

# 是否为AI生成内容平台（影响审查范围）
IS_AI_PLATFORM=true

# 是否包含用户生成内容
HAS_UGC=true

# 是否包含付费功能
HAS_PAYMENT=true

# 支付服务商（stripe/alipay/wechat/paypal）
PAYMENT_PROVIDER=stripe

# 目标市场（逗号分隔：CN,EU,US,JP）
TARGET_MARKETS=CN,US

# 是否为SaaS服务（影响AGPL判断）
IS_SAAS=true

# 项目自身许可证（自动探测时留空）
# PROJECT_LICENSE=MIT

# 依赖许可证扫描输出路径（可选）
# LICENSE_SCAN_PATH=E:\traework\000 做网站赚钱\my-project\licenses.json

# 是否扫描依赖漏洞（默认true）
SCAN_DEPENDENCIES=true
