{
  "software_id": "hongye-municipal-road",
  "name": "鸿业市政道路设计软件",
  "version": "2024",
  "description": "市政道路设计专业软件，支持道路平面、纵断面、横断面设计",
  "platform": ["windows"],
  "interfaces": {
    "cli": {
      "executable": "C:\\Program Files\\Hongye\\MunicipalRoad.exe",
      "command_prefix": "HYRoad",
      "working_directory": "C:\\HongyeProjects"
    },
    "com": {
      "prog_id": "Hongye.MunicipalRoad.Application"
    }
  },
  "command_templates": {
    "create_project": {
      "template": "CreateProject --name {project_name} --type {road_type} --grade {grade}",
      "description": "创建新的市政道路项目",
      "parameters": {
        "project_name": {
          "type": "string",
          "required": true,
          "description": "项目名称"
        },
        "road_type": {
          "type": "enum",
          "required": true,
          "choices": ["municipal", "highway"],
          "description": "道路类型"
        },
        "grade": {
      "type": "enum",
      "required": true,
      "choices": ["express", "arterial", "sub-arterial", "local", "highway-express", "highway-class1", "highway-class2", "highway-class3", "highway-class4"],
      "description": "道路等级"
    }
      },
      "returns": "项目文件路径",
      "verification": {
        "method": "file_exists",
        "criteria": "{project_name}.hyprj 文件存在"
      }
    },
    "set_design_speed": {
      "template": "SetDesignSpeed --speed {speed}",
      "description": "设置设计速度",
      "parameters": {
        "speed": {
          "type": "integer",
          "required": true,
          "description": "设计速度（km/h）"
        }
      },
      "verification": {
        "method": "output_contains",
        "criteria": "Design speed set to"
      }
    },
    "set_lane_count": {
      "template": "SetLaneCount --count {count}",
      "description": "设置车道数",
      "parameters": {
        "count": {
          "type": "integer",
          "required": true,
          "description": "车道数"
        }
      },
      "verification": {
        "method": "output_contains",
        "criteria": "Lane count set to"
      }
    },
    "draw_alignment": {
      "template": "DrawAlignment --start {start_point} --end {end_point} --radius {radius}",
      "description": "绘制道路线形",
      "parameters": {
        "start_point": {
          "type": "point",
          "required": true,
          "description": "起点坐标（x,y）"
        },
        "end_point": {
          "type": "point",
          "required": true,
          "description": "终点坐标（x,y）"
        },
        "radius": {
          "type": "float",
          "required": false,
          "default": 0,
          "description": "曲线半径（m），0表示直线"
        }
      },
      "verification": {
        "method": "output_contains",
        "criteria": "Alignment created"
      }
    }
  },
  "context_mapping": {
    "project_name": {
      "source_field": "project_name",
      "target_parameter": "project_name",
      "transform": "direct",
      "description": "项目名称，需用户在命令构建阶段提供或使用默认值"
    },
    "road_type": {
      "source_field": "road_category",
      "target_parameter": "road_type",
      "transform": "direct"
    },
    "grade": {
      "source_field": "road_grade",
      "target_parameter": "grade",
      "transform": "enum_map"
    },
    "design_speed": {
      "source_field": "design_speed",
      "target_parameter": "speed",
      "transform": "select",
      "description": "从可选速度数组中选取一个值，需用户确认或取第一个"
    },
    "lane_count": {
      "source_field": "lane_count",
      "target_parameter": "count",
      "transform": "select",
      "description": "从可选车道数数组中选取一个值，需用户确认或取第一个"
    }
  }
}
