{
  "name": "yunshu-system-skill",
  "version": "3.6.0",
  "platform": "trae",
  "entry": "SKILL.md",
  "stateDirectory": ".yunshu",
  "commands": {
    "projectRootPrefix": "python .trae/skills/yunshu-system-skill/scripts/yunshu.py --root .",
    "init": "python .trae/skills/yunshu-system-skill/scripts/yunshu.py --root . init",
    "checkpointCreate": "python .trae/skills/yunshu-system-skill/scripts/yunshu.py --root . checkpoint create",
    "checkpointList": "python .trae/skills/yunshu-system-skill/scripts/yunshu.py --root . checkpoint list",
    "checkpointResume": "python .trae/skills/yunshu-system-skill/scripts/yunshu.py --root . checkpoint resume",
    "contextRecord": "python .trae/skills/yunshu-system-skill/scripts/yunshu.py --root . context record",
    "gateTransition": "python .trae/skills/yunshu-system-skill/scripts/yunshu.py --root . gate transition",
    "verifyRun": "python .trae/skills/yunshu-system-skill/scripts/yunshu.py --root . verify run",
    "auditLinks": "python .trae/skills/yunshu-system-skill/scripts/yunshu.py --root . audit links",
    "versionCheck": "python .trae/skills/yunshu-system-skill/scripts/yunshu.py --root . version-check"
  },
  "agents": [
    {
      "name": "yunshu-implementer",
      "prompt": "agents/yunshu-implementer/AGENT.md",
      "tools": ["read", "write", "search", "terminal"]
    },
    {
      "name": "yunshu-spec-reviewer",
      "prompt": "agents/yunshu-spec-reviewer/AGENT.md",
      "tools": ["read", "search", "terminal"]
    },
    {
      "name": "yunshu-quality-reviewer",
      "prompt": "agents/yunshu-quality-reviewer/AGENT.md",
      "tools": ["read", "search", "terminal"]
    }
  ],
  "interaction": {
    "choiceTool": "AskUserQuestion",
    "fallback": "Ask one concise plain-language question and record that AskUserQuestion was unavailable."
  }
}
