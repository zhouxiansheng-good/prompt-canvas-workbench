{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yunshu.local/schemas/checkpoint.schema.json",
  "title": "Yunshu Checkpoint",
  "type": "object",
  "required": [
    "task_id",
    "checkpoint_id",
    "phase",
    "created_at",
    "completed",
    "pending",
    "artifacts"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "init",
        "plan",
        "execute",
        "subagent",
        "accept",
        "deliver",
        "recover"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "completed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pending": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
