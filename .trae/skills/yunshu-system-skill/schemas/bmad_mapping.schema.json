{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yunshu.local/schemas/bmad_mapping.schema.json",
  "title": "Yunshu BMad Mapping",
  "type": "object",
  "required": [
    "task_id",
    "map_id",
    "kind",
    "created_at",
    "updated_at",
    "sources",
    "sections",
    "gaps"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "map_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "architecture",
        "prd",
        "project-context",
        "story"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "exists": {
            "type": "boolean"
          },
          "kind": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "modified_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": true
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "headings"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "headings": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "context_id": {
      "type": "string",
      "minLength": 1
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_read": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
