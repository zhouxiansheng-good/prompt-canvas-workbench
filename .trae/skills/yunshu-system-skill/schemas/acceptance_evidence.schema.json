{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yunshu.local/schemas/acceptance_evidence.schema.json",
  "title": "Yunshu Acceptance Evidence",
  "type": "object",
  "required": [
    "task_id",
    "run_id",
    "status",
    "created_at",
    "dod_items"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "inconclusive"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "dod_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "status",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "inconclusive"
            ]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "failure_capture": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
