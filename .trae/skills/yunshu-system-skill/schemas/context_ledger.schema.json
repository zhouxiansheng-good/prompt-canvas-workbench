{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yunshu.local/schemas/context_ledger.schema.json",
  "title": "Yunshu Context Ledger",
  "type": "object",
  "required": [
    "task_id",
    "context_id",
    "phase",
    "created_at",
    "updated_at",
    "sources"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "context_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "init",
        "plan",
        "execute",
        "subagent",
        "accept",
        "deliver",
        "recover"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "exists": {
            "type": "boolean"
          },
          "kind": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "modified_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": true
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_read": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
